# Mahalakshmi Home Pickles configuration example
# Copy this file to .env and fill in your real values.

PORT=3000

# UPI payment (shown in checkout QR code)
UPI_ID=9700511609@ybl
UPI_PAYEE_NAME=Mahalakshmi Home Pickles

# Gmail SMTP for email notifications
GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=your-gmail-app-password
ORDER_EMAIL=orders@example.com

# Twilio WhatsApp settings
# Use a valid Twilio account SID and auth token.
# For WhatsApp sandbox testing, use the Twilio sandbox number and join code.
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ORDER_WHATSAPP_TO=+919XXXXXXXXX

# CallMeBot WhatsApp settings
# Optional: set WHATSAPP_PROVIDER=callmebot to use CallMeBot instead of Twilio.
WHATSAPP_PROVIDER=callmebot
CALLMEBOT_API_KEY=your_callmebot_api_key
CALLMEBOT_PHONE=919XXXXXXXXXX

# Razorpay live payment gateway
# Set PAYMENT_MODE=razorpay to enable Razorpay checkout.
PAYMENT_MODE=razorpay
RAZORPAY_KEY_ID=rzp_live_yourKeyId
RAZORPAY_KEY_SECRET=yourKeySecret
